# --- Обязательные ---
ANTHROPIC_API_KEY=sk-ant-...
NOTION_TOKEN=ntn_...
APP_PASSWORD=придумай-пароль-входа
SECRET_KEY=длинная-случайная-строка-для-подписи-cookie

# --- Базы Notion (общая память с Second Brain) ---
NOTION_TODOLIST_DB_ID=          # база «Задачи» — та же, что у бота Паолы
NOTION_HABITS_DB_ID=            # база «Привычки» (схема — в README)
NOTION_HABIT_LOG_DB_ID=         # база «Журнал привычек» (схема — в README)
NOTION_REMINDERS_DB_ID=         # база «Напоминания» (схема — в README)

# --- Интеграции ---
GOOGLE_TOKEN_JSON=              # тот же JSON, что у бота Паолы
GOOGLE_CLIENT_SECRET_JSON=     # учётные данные OAuth-клиента; нужны для перевыпуска токена через auth_google.py
TELEGRAM_BOT_TOKEN=             # можно токен Паолы — пуши придут от неё
OWNER_CHAT_ID=

# --- Поведение ---
DIGESTS_TO_TELEGRAM=0           # 1 = слать утро/вечер в Telegram (выключено, пока работает Паола)
